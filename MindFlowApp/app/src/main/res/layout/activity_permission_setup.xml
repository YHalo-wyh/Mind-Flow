<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary"
    android:padding="24dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="欢迎使用 MindFlow"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="为了让 AI 能够帮助你专注，请开启以下权限"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp" />

    <!-- 无障碍服务 -->
    <LinearLayout
        android:id="@+id/layoutAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:padding="18dp"
        android:elevation="2dp"
        android:clipToOutline="true"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_permission_item">

        <ImageView
            android:id="@+id/ivAccessibility"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/checkbox_off_background"
            android:tint="@color/text_hint" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="无障碍服务"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvAccessibilityStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="往下滑找到【MindFlow】并开启"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccessibility"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="开启"
            android:textSize="12sp"
            app:cornerRadius="18dp" />
    </LinearLayout>

    <!-- 悬浮窗权限 -->
    <LinearLayout
        android:id="@+id/layoutOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:padding="18dp"
        android:elevation="2dp"
        android:clipToOutline="true"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_permission_item">

        <ImageView
            android:id="@+id/ivOverlay"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/checkbox_off_background"
            android:tint="@color/text_hint" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="悬浮窗权限"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvOverlayStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用于显示锁定界面"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOverlay"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="开启"
            android:textSize="12sp"
            app:cornerRadius="18dp" />
    </LinearLayout>

    <!-- 使用统计权限 -->
    <LinearLayout
        android:id="@+id/layoutUsageStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:padding="18dp"
        android:elevation="2dp"
        android:clipToOutline="true"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_permission_item">

        <ImageView
            android:id="@+id/ivUsageStats"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/checkbox_off_background"
            android:tint="@color/text_hint" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="应用使用统计"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvUsageStatsStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用于检测前台应用"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUsageStats"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="开启"
            android:textSize="12sp"
            app:cornerRadius="18dp" />
    </LinearLayout>

    <!-- 说明文字 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="这些权限仅用于本地分析，不会上传任何隐私数据"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:gravity="center" />

    <!-- 底部按钮 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFinish"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="请先开启所有权限"
        android:textSize="16sp"
        android:enabled="false"
        app:cornerRadius="28dp" />

</LinearLayout>
